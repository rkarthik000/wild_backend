# ── WildGuard AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Everything is optional — the server runs in local/mock mode without any keys.

# ── Supabase (optional — uses SQLite if not set) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ── Twilio SMS (optional — logs to console if not set) ────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+12015551234

# ── AI Models ─────────────────────────────────────────────────────────────────
# Default is yolov8n.pt (auto-downloaded). Swap for a custom wildlife model.
YOLO_MODEL=yolov8n.pt
SPECIES_MODEL=microsoft/resnet-50

# ── Thresholds ────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.60        # min confidence to log an incident
HIGH_THREAT_CONFIDENCE=0.80      # min confidence to trigger SMS alert

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
